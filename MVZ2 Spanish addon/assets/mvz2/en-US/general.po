#. Description for command "mvz2:spawn"
#: Commands meta file
msgctxt "command.description"
msgid "生成一个实体。"
msgstr "Genera una entidad."

#. Description for command variant "mvz2:spawn pos"
#: Commands meta file
msgctxt "command_variant.description"
msgid "生成一个实体。默认位置为场地中心。"
msgstr ""
"Genera una entidad. La ubicación por defecto es el centro del campo de batalla."

#. Description for parameter id of command "mvz2:spawn pos"
#: Commands meta file
msgctxt "command_parameter.description"
msgid "要生成的实体ID。"
msgstr "El ID de la entidad a generar."

#. Description for parameter x of command "mvz2:spawn pos"
#: Commands meta file
msgctxt "command_parameter.description"
msgid "可选。要生成的实体位置的X值。"
msgstr "Opcional. La posición X donde se genera la entidad."

#. Description for parameter y of command "mvz2:spawn pos"
#: Commands meta file
msgctxt "command_parameter.description"
msgid "可选。要生成的实体位置的Y值。"
msgstr "Opcional. La posición Y donde se genera la entidad."

#. Description for parameter z of command "mvz2:spawn pos"
#: Commands meta file
msgctxt "command_parameter.description"
msgid "可选。要生成的实体位置的Z值。"
msgstr "Opcional. La posición Z donde se genera la entidad."

#. Description for command variant "mvz2:spawn tile"
#: Commands meta file
msgctxt "command_variant.description"
msgid "在指定的地格位置生成实体。默认位置为场地中心。"
msgstr ""
"Genera una entidad en una casilla específica. La ubicación por defecto es "
"el centro del campo de batalla."

#. Description for parameter column of command "mvz2:spawn tile"
#: Commands meta file
msgctxt "command_parameter.description"
msgid "可选。实体所在列。0代表最左侧一列，向右递增。"
msgstr ""
"Opcional. La columna donde se genera la entidad. 0 representa la columna "
"del extremo izquierdo, aumentando hacia la derecha."

#. Description for parameter lane of command "mvz2:spawn tile"
#: Commands meta file
msgctxt "command_parameter.description"
msgid "可选。实体所在行。0代表最上方一行，向下递增。"
msgstr ""
"Opcional. El carril donde se genera la entidad. 0 representa el carril "
"superior, aumentando hacia abajo."

#. Description for command "mvz2:kill"
#: Commands meta file
